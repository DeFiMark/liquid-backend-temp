# JWT signing secret (HS256) — generate a strong random string
JWT_SECRET=your-jwt-secret-here

# Base mainnet RPC URL (Alchemy, Infura, etc.)
BASE_RPC_URL=https://mainnet.base.org

# Application domain for SIWE message validation
APP_DOMAIN=localhost

# Server port
PORT=3000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
PLAID_IDV_TEMPLATE_ID=your-idv-template-id
PLAID_WEBHOOK_SECRET=your-webhook-secret

# Circle
CIRCLE_API_KEY=your-circle-api-key

# Encryption
ENCRYPTION_KEY=your-64-char-hex-key

# Thirdweb
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
THIRDWEB_CLIENT_ID=your-thirdweb-client-id
THIRDWEB_ACCOUNT_FACTORY=0x85e23b94e7F5E9cC1fF78BCe78cfb15B81f0DF00
