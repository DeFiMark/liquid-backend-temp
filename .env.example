# =============================================================================
# Liquid Backend — Environment Variables
# =============================================================================
# Copy to .env for local dev, or set in Railway dashboard for deployment.
# ALL values below are required unless marked (optional).

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3001
NODE_ENV=sandbox                          # sandbox | production
CORS_ORIGINS=https://getliquid.io        # Comma-separated frontend origins
APP_DOMAIN=getliquid.io                   # Domain for SIWE challenge messages

# ---------------------------------------------------------------------------
# Auth — generate fresh for each environment
# ---------------------------------------------------------------------------
JWT_SECRET=                               # openssl rand -hex 64

# ---------------------------------------------------------------------------
# Encryption — AES-256-GCM key for KYC PII + bank tokens
# ⚠️ CRITICAL: losing this key = all encrypted data unrecoverable
# Store in a password manager immediately after generating
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=                           # openssl rand -hex 32

# ---------------------------------------------------------------------------
# Supabase — from dashboard: Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co     # Project URL
SUPABASE_SERVICE_ROLE_KEY=                # service_role key (secret!)

# ---------------------------------------------------------------------------
# Plaid — from dashboard.plaid.com
# ---------------------------------------------------------------------------
PLAID_CLIENT_ID=                          # Plaid client ID
PLAID_SECRET=                             # Sandbox or production secret
PLAID_ENV=sandbox                         # sandbox | production
PLAID_IDV_TEMPLATE_ID=                    # Identity Verification template
PLAID_WEBHOOK_URL=                        # https://<your-domain>/webhooks/plaid
# PLAID_WEBHOOK_SECRET=                   # (optional) For webhook signature verification

# ---------------------------------------------------------------------------
# Circle Mint — from app-sandbox.circle.com or app.circle.com
# ---------------------------------------------------------------------------
CIRCLE_API_KEY=                           # Sandbox or production API key

# ---------------------------------------------------------------------------
# Blockchain
# ---------------------------------------------------------------------------
BASE_RPC_URL=https://mainnet.base.org     # Base mainnet RPC

# ---------------------------------------------------------------------------
# Rate Limiting — Upstash Redis (optional for local dev, required for prod)
# Free tier: https://upstash.com — 10K commands/day
# ---------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=                 # (optional) Falls back to in-memory if not set
# UPSTASH_REDIS_REST_TOKEN=               # (optional) Falls back to in-memory if not set
